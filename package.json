{
  "name": "doom-game-webgl",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Empty React app scaffolded with the doom-webgl toolchain (TS, ESLint, Biome, Vitest, Playwright, jscpd, Husky)",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "ts": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0 --no-warn-ignored",
    "lint:fix": "eslint . --fix --no-warn-ignored",
    "biome": "biome check",
    "biome:fix": "biome check --fix",
    "copies": "jscpd ./src",
    "check": "tsc --noEmit && biome check && eslint . --max-warnings 0 --no-warn-ignored",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "prepare": "husky || true"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "jsdom": "^25.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.0.7",
    "vitest": "^4.1.0"
  }
}
